SUPABASE_URL=
SUPABASE_SERVICE_KEY=
RESEND_API_KEY=
CAREGIVER_EMAIL=
TAILSCALE_IP=
# ElevenLabs API key from your hackathon credits account
ELEVENLABS_API_KEY=your_api_key_here
# Voice ID from ElevenLabs voice library (for example Aria, Sarah, or Charlotte)
ELEVENLABS_VOICE_ID=your_chosen_voice_id_here
# Google Gemini Flash API key from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
# Optional override for model family
GEMINI_MODEL=gemini-2.5-flash-lite
# Cooldown windows used when Gemini returns 429 rate limit.
GEMINI_GLOBAL_RATE_LIMIT_SECONDS=120
GEMINI_MODEL_RATE_LIMIT_SECONDS=180
# Path to OpenWakeWord ONNX model used for "Hey Clarity" detection
OPENWAKEWORD_MODEL_PATH=./models/hey_clarity.onnx
# Set true only if wake-word dependencies and model files are installed.
WAKE_WORD_ENABLED=false

# Path to the trained YOLO custom weights file
CUSTOM_MODEL_PATH=./models/best.pt

# Demo class labels expected by backend logic:
# rj, mayank, harshal, orange_bottle, white_bottle

# Minimum confidence score for a detection to be acted on (0.0 to 1.0)
# 0.60 is recommended — lower this if detections are being missed, raise it if false positives appear
DETECTION_CONFIDENCE_THRESHOLD=0.55

# Optional: lower confidence threshold used for drawing overlay boxes.
# Alerts still use DETECTION_CONFIDENCE_THRESHOLD.
OVERLAY_CONFIDENCE_THRESHOLD=0.30

DEMO_PERSON_NAME=RJ
DEMO_PERSON_RELATIONSHIP=son
SCHEDULER_TIMEZONE=America/Chicago
